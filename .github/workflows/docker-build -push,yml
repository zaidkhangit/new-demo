name: docker build & push
on:
  workflow_dispatch:
jobs:
  runs-on: ubuntu-latest
    
  deploy:
    env:
       OCKERHUB_USER : ${{ vars.DOCKERHUB_USER }}
       DOCKER_TAG: ${{ github.sha}}
    steps:
      - name: checkout_code
        uses: actions/checkout@v4
      - name: deploy with docker-compose
        uses: docker compose down && docker compose up -d --build --force-recreate --pull always
